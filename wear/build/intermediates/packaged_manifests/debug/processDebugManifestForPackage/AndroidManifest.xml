<?xml version="1.0" encoding="utf-8"?>
<!-- AndroidManifest.xml модуля :wear (часы Wear OS) -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.wearmorse.phone"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="34" />

    <!-- Микрофон, вибрация, фоновая запись и пробуждение -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MICROPHONE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Объявляем, что это приложение для часов -->
    <uses-feature android:name="android.hardware.type.watch" />

    <permission
        android:name="com.wearmorse.phone.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.wearmorse.phone.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.WearMorseMessenger" >

        <!-- Экран управления: статус микрофона, последнее сообщение, кнопка ВКЛ/ВЫКЛ -->
        <activity
            android:name="com.wearmorse.wear.WearMainActivity"
            android:exported="true"
            android:theme="@style/Theme.WearMorseMessenger" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Фоновый сервис: запись микрофона, стрим на телефон, приём Морзе -->
        <service
            android:name="com.wearmorse.wear.SecretSpyService"
            android:exported="false"
            android:foregroundServiceType="microphone" />

        <meta-data
            android:name="com.google.android.wearable.standalone"
            android:value="false" />

        <uses-library
            android:name="com.google.android.wearable"
            android:required="false" />

        <activity
            android:name="com.google.android.gms.common.api.GoogleApiActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />
    </application>

</manifest>