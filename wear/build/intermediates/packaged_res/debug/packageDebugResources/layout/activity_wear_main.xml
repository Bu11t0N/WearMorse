<?xml version="1.0" encoding="utf-8"?>
<!-- Разметка WearMainActivity — экран управления на часах -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <!-- Статус микрофона -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/mic_status_label"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/micStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="4dp"
            android:paddingBottom="8dp"
            android:text="@string/mic_status_off"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Кнопка-переключатель микрофона -->
        <Button
            android:id="@+id/micToggleButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:text="@string/mic_turn_on" />

        <!-- Последнее сообщение с телефона -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/last_message_label"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/lastMessageText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:minHeight="64dp"
            android:paddingTop="6dp"
            android:text="@string/last_message_empty"
            android:textSize="14sp" />

    </LinearLayout>
</ScrollView>
